{
  "version": 2,
  "buildCommand": "cd frontend && npm ci --production=false && npm run build",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
